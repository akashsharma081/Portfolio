# Backend Settings
DATABASE_URL=sqlite:///./portfolio.db
SECRET_KEY=generate_a_secure_jwt_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default Admin User Credentials
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=AdminSecure123!

# CORS Configuration
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,https://your-production-domain.vercel.app
